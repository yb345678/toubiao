APP_NAME=AI Bidding Multi-Agent Platform
API_V1_PREFIX=/api/v1
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080
# Local/Docker default. For Vercel production, use a managed PostgreSQL URL.
DATABASE_URL=sqlite:///./database/app.db
# Local/Docker default. Vercel filesystem is ephemeral; use cloud object storage for production files.
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
BLOB_READ_WRITE_TOKEN=
FRONTEND_URL=
CORS_ORIGINS=
MAX_UPLOAD_SIZE_MB=50

BACKEND_PORT=8000
FRONTEND_PORT=5173

# Leave empty for Hugging Face single-container same-origin deployment.
# For Vercel frontend deployment, set this to the public Vercel backend URL.
VITE_API_BASE_URL=
STATIC_DIR=
